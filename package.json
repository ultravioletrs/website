{
  "name": "ultraviolet-website",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "cf:dev": "astro build && wrangler pages dev dist",
    "deploy": "astro build && wrangler pages deploy dist",
    "check": "astro check",
    "lint": "eslint . --report-unused-disable-directives",
    "lint:fix": "eslint . --fix --report-unused-disable-directives",
    "format": "prettier --write \"**/*.{ts,tsx,mjs,astro,css,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,mjs,astro,css,md,json}\"",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/tailwind": "^6.0.2",
    "astro": "^5.17.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@eslint/css": "^1.0.0",
    "@eslint/js": "^9.39.4",
    "@eslint/json": "^1.1.0",
    "@eslint/markdown": "^7.5.1",
    "@tailwindcss/typography": "^0.5.19",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-prettier": "^5.2.5",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "wrangler": "^4.77.0"
  }
}

---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const featuredPost = posts[0];
const regularPosts = posts.slice(1);

const title = "Ultraviolet Blog";
const description = "Latest news, updates, and insights from the Ultraviolet team on confidential computing and secure AI.";
---

<Layout title={title} description={description}>
	<Header slot="header" />

    <div class="pt-0">
        <Hero
            title="Ultraviolet Blog"
            description="Technical articles, product updates, and engineering deep dives from the Ultraviolet team on building open-source confidential computing & secure AI Platforms."
            alignment="center"
        />
    </div>

	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
		<div class="flex flex-col lg:flex-row gap-8">
			<div class="lg:w-2/3">
				<div class="grid gap-6" id="blogGrid">
					{featuredPost && (
						<div
							class="blog-card border border-border bg-card transition-colors duration-200 hover:bg-surface reveal"
							data-title={featuredPost.data.title.toLowerCase()}
							data-tags={featuredPost.data.tags?.join(',').toLowerCase() || ''}
							data-excerpt={(featuredPost.data.excerpt || featuredPost.data.description || '').toLowerCase()}
						>
							<a href={`/blog/${featuredPost.slug}`} class="block">
								{featuredPost.data.image && (
									<div class="border-b border-border overflow-hidden">
										<Image class="block h-56 w-full object-cover" src={featuredPost.data.image} alt={featuredPost.data.title} loading="lazy" width={1200} height={630} />
									</div>
								)}
								<div class="p-6">
									<div class="flex flex-wrap gap-2 mb-3">
										{featuredPost.data.category && (
											<span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300">
												{featuredPost.data.category}
											</span>
										)}
										<span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300">
											Featured
										</span>
									</div>
									<h2 class="text-2xl font-bold text-text-main font-heading mb-3">{featuredPost.data.title}</h2>
									<p class="text-text-muted line-clamp-3 mb-4 font-body">{featuredPost.data.excerpt || featuredPost.data.description}</p>
									<div class="flex items-center">
										{(() => {
											const authors = featuredPost.data.authors || (featuredPost.data.author ? [featuredPost.data.author] : []);
											return (
												<>
													<div class="flex -space-x-2 mr-3 flex-shrink-0">
														{authors.map((author) => (
author.picture && <Image class="h-8 w-8 rounded-full object-cover ring-2 ring-background" src={author.picture} alt={author.name} loading="lazy" width={32} height={32} />
															))}
														</div>
														<div class="text-sm">
															<p class="font-semibold text-text-main">
																{authors.map((a) => a.name).join(', ')}
															</p>
															<p class="text-text-muted">
																{post.data.date.toLocaleDateString
														</p>
													</div>
												</>
											);
										})()}
									</div>
									{featuredPost.data.tags && (
										<div class="flex flex-wrap gap-2 mt-4">
																																																																																																								{featuredPost.data.tags.map((tag) => (
												<span class="mg-blog-tag inline-flex items-center px-2 py-0.5 rounded text-xs bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300">
													{tag}
												</span>
											))}
										</div>
									)}
								</div>
							</a>
						</div>
					)}

					<div class="grid md:grid-cols-2 gap-6">
						{regularPosts.map((post) => (
							<div
								class="blog-card border border-border bg-card transition-colors duration-200 hover:bg-surface flex flex-col h-full reveal"
								data-title={post.data.title.toLowerCase()}
								data-tags={post.data.tags?.join(',').toLowerCase() || ''}
								data-excerpt={(post.data.excerpt || post.data.description || '').toLowerCase()}
							>
								<a href={`/blog/${post.slug}`} class="flex-1 flex flex-col">
									{post.data.image && (
										<div class="border-b border-border overflow-hidden">
											<Image class="block h-48 w-full object-cover" src={post.data.image} alt={post.data.title} loading="lazy" width={800} height={420} />
										</div>
									)}
									<div class="p-6">
										{post.data.category && (
											<div class="mb-2">
												<span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium bg-primary/10 text-primary-text">
													{post.data.category}
												</span>
											</div>
										)}
										<h2 class="text-lg font-bold text-text-main font-heading mb-2 line-clamp-2">{post.data.title}</h2>
										<p class="text-sm text-text-muted line-clamp-3 mb-4 font-body">{post.data.excerpt || post.data.description}</p>
										<div class="flex items-center mt-auto">
											{(() => {
												const authors = post.data.authors || (post.data.author ? [post.data.author] : []);
												return (
													<>
														<div class="flex -space-x-2 mr-3 flex-shrink-0">
															{authors.map((author) => (
																author.picture && <Image class="h-8 w-8 rounded-full object-cover ring-2 ring-background" src={author.picture} alt={author.name} loading="lazy" width={32} height={32} inferSize />
															))}
														</div>
														<div class="text-sm min-w-0">
															<p class="font-semibold text-text-main truncate">
																{authors.map((a) => a.name).join(', ')}
															</p>
															<p class="text-text-muted">
																{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })} · {Math.ceil(post.body.split(/\s+/).length / 200)} min
															</p>
														</div>
													</>
												);
											})()}
										</div>
										{post.data.tags && (
											<div class="flex flex-wrap gap-1 mt-3">
																																																												{post.data.tags.slice(0, 4).map((tag) => (
													<span class="mg-blog-tag inline-flex items-center px-2 py-0.5 rounded text-xs bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300">
														{tag}
													</span>
												))}
											</div>
										)}
									</div>
								</a>
							</div>
						))}
					</div>
				</div>
			</div>

			<div class="lg:w-1/3">
				<div class="lg:pl-6 space-y-6 reveal reveal-delay-2">
					<div class="relative">
						<div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-text-muted">
							<i class="fas fa-search" aria-hidden="true"></i>
						</div>
						<input
							type="text"
							id="searchInput"
							placeholder="Search blogs..."
							class="w-full pl-10 pr-4 py-3 border border-border bg-surface text-text-main focus:ring-1 focus:ring-primary focus:border-primary outline-none transition-colors"
							aria-label="Search blogs"
						/>
					</div>

					<div class="am-categories">
						<h5 class="font-bold text-text-main mb-3">Categories</h5>
						<div class="flex flex-wrap gap-2" id="categoryFilters">
							<button
								class="category-btn px-3 py-1.5 rounded text-sm font-medium transition-colors bg-primary text-white"
								data-category="all"
							>
								All
							</button>
							<button
								class="category-btn px-3 py-1.5 rounded text-sm font-medium transition-colors bg-gray-200 text-gray-700 dark:bg-gray-700 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-gray-600"
								data-category="prism ai"
							>
								Prism AI
							</button>
							<button
								class="category-btn px-3 py-1.5 rounded text-sm font-medium transition-colors bg-gray-200 text-gray-700 dark:bg-gray-700 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-gray-600"
								data-category="cocos ai"
							>
								Cocos AI
							</button>
							<button
								class="category-btn px-3 py-1.5 rounded text-sm font-medium transition-colors bg-gray-200 text-gray-700 dark:bg-gray-700 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-gray-600"
								data-category="cube ai"
							>
								Cube AI
							</button>
						</div>
					</div>

					<div class="border border-border bg-card p-6">
						<a href="/">
							<img src="/img/logos/UltraViolet_logo-horizontal.svg" alt="Ultraviolet" class="h-8 mb-4 dark:brightness-0 dark:invert" />
						</a>
						<p class="text-text-muted text-sm mb-4">
							Ultraviolet is a leading company specializing in confidential computing, cloud security, AI/ML, multi-party computation, and secure data sharing.
						</p>
						<h6 class="font-bold text-text-main mb-3">Connect with us</h6>
						<div class="flex gap-3">
							<a href="https://github.com/ultravioletrs" target="_blank" class="p-2 text-text-muted hover:text-primary transition-all hover:-translate-y-0.5" aria-label="GitHub">
								<i class="fab fa-github fa-lg"></i>
							</a>
							<a href="https://twitter.com/ultravioletrs" target="_blank" class="p-2 text-text-muted hover:text-primary transition-all hover:-translate-y-0.5" aria-label="Twitter">
								<i class="fab fa-twitter fa-lg"></i>
							</a>
							<a href="https://www.linkedin.com/company/ultravioletrs" target="_blank" class="p-2 text-text-muted hover:text-primary transition-all hover:-translate-y-0.5" aria-label="LinkedIn">
								<i class="fab fa-linkedin fa-lg"></i>
							</a>
							<a href="https://www.youtube.com/@ultravioletrs" target="_blank" class="p-2 text-text-muted hover:text-primary transition-all hover:-translate-y-0.5" aria-label="YouTube">
								<i class="fab fa-youtube fa-lg"></i>
							</a>
						</div>
					</div>

					<div class="border border-border bg-surface px-4 py-6 text-center">
						<h5 class="font-bold text-text-main font-heading mb-2">Subscribe to Our Newsletter</h5>
						<p class="text-text-muted text-sm font-body mb-4">Stay updated with the latest news, updates and announcements.</p>
						<form
							action="https://ultraviolet.us20.list-manage.com/subscribe/post?u=b35e6bdc7b2adf06c56da2265&amp;id=88ed6c4af0&amp;f_id=004f06eaf0"
							method="post"
							target="_blank"
							aria-label="Newsletter subscription"
						>
							<div class="flex flex-col gap-2 sm:flex-row sm:gap-0">
								<input
									type="email"
									name="EMAIL"
									placeholder="Enter your email"
									required
									aria-label="Email address"
									class="w-full sm:flex-1 px-3 py-2 border border-border sm:border-r-0 bg-background text-text-main focus:ring-1 focus:ring-primary focus:border-primary outline-none"
								/>
								<button type="submit" class="w-full sm:w-auto px-3 py-2 bg-primary text-black font-medium border border-primary hover:bg-primary-dark transition-colors uppercase tracking-wide">
									Subscribe
								</button>
							</div>
							<div style="position: absolute; left: -5000px" aria-hidden="true">
								<input type="text" name="b_b35e6bdc7b2adf06c56da2265_88ed6c4af0" tabindex="-1" value="" aria-label="Leave empty" />
							</div>
						</form>
					</div>
				</div>
			</div>
		</div>
	</div>

	<Footer slot="footer" />

    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            const searchInput = document.getElementById('searchInput');
            const categoryButtons = document.querySelectorAll('.category-btn');
            const blogCards = document.querySelectorAll('.blog-card');
            let currentCategory = 'all';

            function filterPosts() {
                const searchTerm = searchInput.value.toLowerCase().trim();

                blogCards.forEach(card => {
                    const title = card.dataset.title;
                    const tags = card.dataset.tags;
                    const excerpt = card.dataset.excerpt;
                    const matchesSearch = title.includes(searchTerm) || tags.includes(searchTerm) || excerpt.includes(searchTerm);
                    const matchesCategory = currentCategory === 'all' || tags.split(',').includes(currentCategory.toLowerCase());

                    if (matchesSearch && matchesCategory) {
                        card.style.display = '';
                    } else {
                        card.style.display = 'none';
                    }
                });
            }

            searchInput.addEventListener('input', filterPosts);

            categoryButtons.forEach(btn => {
                btn.addEventListener('click', () => {
                    categoryButtons.forEach(b => {
                        b.classList.remove('bg-primary', 'text-white');
                        b.classList.add('bg-gray-200', 'text-gray-700', 'dark:bg-gray-700', 'dark:text-gray-300');
                    });
                    btn.classList.remove('bg-gray-200', 'text-gray-700', 'dark:bg-gray-700', 'dark:text-gray-300');
                    btn.classList.add('bg-primary', 'text-white');

                    currentCategory = btn.dataset.category;
                    filterPosts();
                });
            });

            const params = new URLSearchParams(window.location.search);
            const categoryFromURL = params.get('category');
            if (categoryFromURL) {
                const btn = document.querySelector(`.category-btn[data-category="${categoryFromURL}"]`);
                if (btn) btn.click();
            }
        });
    </script>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Newsletter from '../components/Newsletter.astro';
import { Image } from 'astro:assets';

import ccImage from '../assets/mockups/cube_dashboard.png';
import prismConceptImage from '../assets/mockups/prism_dashboard.png';
import openSourceImage from '../assets/open-source.png';

import ifLogo from '../assets/logos/if.png';
import etfLogo from '../assets/logos/etf.png';
import euLogo from '../assets/logos/eu.png';
import telefonicaLogo from '../assets/logos/telefonica.png';
import vttLogo from '../assets/logos/vtt.png';
import fujitsuLogo from '../assets/logos/fujitsu.png';
import fraunhoferLogo from '../assets/logos/fraunhofer.png';
import tnoLogo from '../assets/logos/tno.png';
import ericssonLogo from '../assets/logos/ericsson.png';
import nokiaLogo from '../assets/logos/nokia.png';
import insermLogo from '../assets/logos/inserm.png';
import tueLogo from '../assets/logos/tue.png';
import thalesLogo from '../assets/logos/thales.png';
import imdeaLogo from '../assets/logos/imdea.svg';
import lfLogo from '../assets/logos/lf.png';
import cccLogo from '../assets/logos/ccc.png';

import tucLogo from '../assets/logos/TUC.png';
import imecLogo from '../assets/logos/IMEC.png';
import aalLogo from '../assets/logos/AAL.png';
import lundLogo from '../assets/logos/LUND.png';
import zenLogo from '../assets/logos/zen.png';
import politoLogo from '../assets/logos/POLITO.png';
import amaLogo from '../assets/logos/AMA.png';
import wingsLogo from '../assets/logos/wings-logo.png';
import nokia1Logo from '../assets/logos/nokia-1.png';
import nokiaBellLabsLogo from '../assets/logos/nokia-bellLabs.png';
import tuGratzLogo from '../assets/logos/tu-gratz.png';
import ucdLogo from '../assets/logos/ucd-1.png';
import tuwLogo from '../assets/logos/tuw.png';
import murciaLogo from '../assets/logos/Universidad-de-Murcia.png';
import canarybitLogo from '../assets/logos/canarybit.png';
import f6sLogo from '../assets/logos/f6s.png';
import easternLogo from '../assets/logos/universityofeastern.png';
import odysseusLogo from '../assets/logos/odysseus.png';
import trilateralLogo from '../assets/logos/Trilateral-Research.png';
import chariteLogo from '../assets/logos/charite.png';
import sargaLogo from '../assets/logos/SARGA.png';
import venetoLogo from '../assets/logos/regione-del-veneto.png';
import koblenzLogo from '../assets/logos/university-of-koblenz.png';
import itaLogo from '../assets/logos/ITA.png';

const title = "Open Source Confidential Computing & Secure AI Platform | Ultraviolet";

const clientLogos = [
    { src: ifLogo, alt: "IF" },
    { src: etfLogo, alt: "ETF" },
    { src: euLogo, alt: "EU" },
    { src: telefonicaLogo, alt: "Telefonica" },
    { src: vttLogo, alt: "VTT" },
    { src: fujitsuLogo, alt: "Fujitsu" },
    { src: fraunhoferLogo, alt: "Fraunhofer" },
    { src: tnoLogo, alt: "TNO" },
    { src: ericssonLogo, alt: "Ericsson" },
    { src: nokiaLogo, alt: "Nokia" },
    { src: insermLogo, alt: "Inserm" },
    { src: tueLogo, alt: "TU Eindhoven" },
    { src: thalesLogo, alt: "Thales" },
    { src: imdeaLogo, alt: "IMDEA" },
    { src: tucLogo, alt: "Technical University of Crete" },
    { src: imecLogo, alt: "IMEC" },
    { src: aalLogo, alt: "Aalto University" },
    { src: lundLogo, alt: "Lund University" },
    { src: zenLogo, alt: "Zentrix Labs" },
    { src: politoLogo, alt: "Politecnico di Torino" },
    { src: amaLogo, alt: "AMA" },
    { src: wingsLogo, alt: "Wings" },
    { src: nokia1Logo, alt: "Nokia" },
    { src: nokiaBellLabsLogo, alt: "Nokia Bell Labs" },
    { src: tuGratzLogo, alt: "TU Graz" },
    { src: ucdLogo, alt: "UCD" },
    { src: tuwLogo, alt: "TU Wien" },
    { src: murciaLogo, alt: "Universidad de Murcia" },
    { src: canarybitLogo, alt: "Canarybit" },
    { src: f6sLogo, alt: "F6S" },
    { src: easternLogo, alt: "University of Eastern Finland" },
    { src: odysseusLogo, alt: "Odysseus Data Services" },
    { src: trilateralLogo, alt: "Trilateral Research" },
    { src: chariteLogo, alt: "Charité University Hospital" },
    { src: sargaLogo, alt: "SARGA" },
    { src: venetoLogo, alt: "Regione del Veneto" },
    { src: koblenzLogo, alt: "University of Koblenz" },
    { src: itaLogo, alt: "ITA" },
];
---

<Layout title={title}>
	<Header slot="header" />
	
	<Hero
        alignment="center"
		title="Confidential Computing<br />for Enterprise AI"
		description="The open-source platform for secure collaborative AI and private LLM deployment. Protect your data in use, from edge to cloud."
		ctaText="Explore Products"
		ctaLink="/products"
	/>

	<section class="border-b border-border py-12">
		<div class="px-4 text-center reveal">
      <h2 class="text-sm font-body text-text-muted mb-8 tracking-widest uppercase">Our Memberships</h2>
			<div class="flex justify-center flex-wrap gap-12 items-center transition-opacity">
				<a href="https://www.linuxfoundation.org/" target="_blank" class="bg-white px-4 py-3">
                    <Image src={lfLogo} alt="Linux Foundation" class="h-14 w-auto object-contain transition-all" loading="eager" />
                </a>
                <a href="https://confidentialcomputing.io/" target="_blank" class="bg-white px-4 py-3">
                    <Image src={cccLogo} alt="Confidential Computing Consortium" class="h-14 w-auto object-contain transition-all" loading="eager" />
                </a>
			</div>
		</div>
	</section>

    <section class="bg-background border-b border-border transition-colors duration-300">
    <div class="px-4 py-10 text-center border-b border-border reveal">
      <h2 class="text-sm font-body text-text-muted tracking-widest uppercase">Our Clients and Partners</h2>
    </div>
        <div class="overflow-hidden py-6">
            <div class="clients-marquee-track flex w-max items-center">
                {[...clientLogos, ...clientLogos].map((logo, index) => {
                    const isDuplicate = index >= clientLogos.length;

                    return (
                        <div
                            class="clients-marquee-item flex justify-center items-center px-10 py-6"
                            aria-hidden={isDuplicate ? 'true' : undefined}
                        >
                            <div class="bg-white px-4 py-3">
                                <Image src={logo.src} alt={logo.alt} class="h-14 w-auto object-contain transition-all" loading="lazy" />
                            </div>
                        </div>
                    );
                })}
            </div>
        </div>
    </section>

    <section id="cube-ai" class="py-24 border-b border-border bg-background">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="lg:grid lg:grid-cols-5 lg:gap-12 xl:gap-16 lg:items-center">
                <div class="lg:col-span-2 mb-12 lg:mb-0 reveal-left">
                    <div class="mb-6 flex items-center text-sm font-bold text-primary-text uppercase tracking-wider">
                        <span class="w-2 h-1 bg-primary-text mr-3 inline-block"></span> Cube AI <span class="w-2 h-1 bg-primary-text ml-3 inline-block"></span>
                    </div>
                    <h2 class="text-4xl md:text-5xl font-heading mb-6 text-text-main leading-tight">
                        Uncompromising Confidentiality
                    </h2>
                    <div class="mb-8 text-lg text-text-muted leading-relaxed space-y-4">
                        <p class="font-medium text-text-main text-xl">Run LLMs inside hardware-based Trusted Execution Environments (AMD SEV, Intel TDX).</p>
                        <p>Cloud operators cannot access prompts, weights, or outputs.</p>
                        <ul class="space-y-3 mt-4">
                            <li class="flex items-start">
                                <i class="fas fa-check text-primary-text mt-1.5 mr-3"></i>
                                <span>Enforce governance at runtime.</span>
                            </li>
                            <li class="flex items-start">
                                <i class="fas fa-check text-primary-text mt-1.5 mr-3"></i>
                                <span>Generate verifiable audit logs.</span>
                            </li>
                            <li class="flex items-start">
                                <i class="fas fa-check text-primary-text mt-1.5 mr-3"></i>
                                <span>Prevent prompt injection at the infrastructure layer.</span>
                            </li>
                        </ul>
                    </div>
                    <a href="https://cube.ultraviolet.rs" target="_blank" class="mt-4 bg-transparent border border-dashed border-border text-text-main font-medium py-3 px-8 hover:bg-surface transition-colors inline-block uppercase tracking-wide">
                        Explore Cube
                    </a>
                </div>
                <div class="lg:col-span-3 flex justify-center items-center reveal-right">
                     <Image class="w-full h-auto rounded-lg border-2 border-gray-500" src={ccImage} alt="Cube AI Dashboard" loading="lazy" />
                </div>
            </div>
        </div>
    </section>

    <section id="prism-ai" class="py-24 border-b border-border bg-background">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="lg:grid lg:grid-cols-5 lg:gap-12 xl:gap-16 lg:items-center">
                <div class="lg:col-span-2 mb-12 lg:mb-0 reveal-left">
                    <div class="mb-6 flex items-center text-sm font-bold text-primary-text uppercase tracking-wider">
                        <span class="w-2 h-1 bg-primary-text mr-3 inline-block"></span> Prism AI <span class="w-2 h-1 bg-primary-text ml-3 inline-block"></span>
                    </div>
                    <h2 class="text-4xl md:text-5xl font-heading mb-6 text-text-main leading-tight">
                        Secure Multi-Party Collaboration
                    </h2>
                    <div class="mb-8 text-lg text-text-muted leading-relaxed space-y-4">
                        <p class="font-medium text-text-main text-xl">Unlock distributed data without exposing intellectual property.</p>
                        <ul class="space-y-3 mt-4">
                            <li class="flex items-start">
                                <span class="w-1.5 h-1.5 bg-primary-text rounded-full mt-2.5 mr-3 flex-shrink-0"></span>
                                <span>Hardware-backed Remote Attestation</span>
                            </li>
                            <li class="flex items-start">
                                <span class="w-1.5 h-1.5 bg-primary-text rounded-full mt-2.5 mr-3 flex-shrink-0"></span>
                                <span>Hierarchical RBAC (Dataset Providers vs Algorithm Providers)</span>
                            </li>
                            <li class="flex items-start">
                                <span class="w-1.5 h-1.5 bg-primary-text rounded-full mt-2.5 mr-3 flex-shrink-0"></span>
                                <span>Policy-driven orchestration</span>
                            </li>
                            <li class="flex items-start">
                                <span class="w-1.5 h-1.5 bg-primary-text rounded-full mt-2.5 mr-3 flex-shrink-0"></span>
                                <span>aTLS-secured in-enclave execution</span>
                            </li>
                        </ul>
                    </div>
                    <a href="https://prism.ultraviolet.rs" target="_blank" class="mt-4 bg-transparent border border-dashed border-border text-text-main font-medium py-3 px-8 hover:bg-surface transition-colors inline-block uppercase tracking-wide">
                        Explore Prism
                    </a>
                </div>
                <div class="lg:col-span-3 flex justify-center items-center reveal-right">
                     <Image class="w-full h-auto rounded-lg border-2 border-gray-500" src={prismConceptImage} alt="Prism AI Dashboard" loading="lazy" />
                </div>
            </div>
        </div>
    </section>

    <section id="cocos-ai" class="py-24 border-b border-border bg-background">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="lg:grid lg:grid-cols-5 lg:gap-16 lg:items-center">
                <div class="lg:col-span-2 mb-10 lg:mb-0 reveal-left">
                    <div class="mb-6 flex items-center text-sm font-bold text-primary-text uppercase tracking-wider">
                        <span class="w-2 h-1 bg-primary-text mr-3 inline-block"></span> Cocos AI <span class="w-2 h-1 bg-primary-text ml-3 inline-block"></span>
                    </div>
                    <h2 class="text-4xl md:text-5xl font-heading mb-6 text-text-main leading-tight">
                        The Open-Source Standard
                    </h2>
                    <div class="mb-8 text-lg text-text-muted leading-relaxed space-y-4">
                        <p class="font-medium text-text-main text-xl">True security requires transparency.</p>
                        <p>Cocos AI is fully open source, independently auditable, and community governed.</p>
                    </div>
                    <a href="https://cocos.ai" target="_blank" class="mt-4 bg-transparent border border-dashed border-border text-text-main font-medium py-3 px-8 hover:bg-surface transition-colors inline-block uppercase tracking-wide">
                        Explore Cocos
                    </a>
                </div>
                <div class="lg:col-span-3 flex justify-center items-center reveal-right">
                     <Image class="w-full h-auto rounded-lg border-2 border-gray-500 opacity-80" src={openSourceImage} alt="Cocos AI architecture diagram" loading="lazy" />
                </div>
            </div>
        </div>
    </section>
    
    <section class="py-24 bg-background text-center">
        <div class="max-w-3xl mx-auto px-4 reveal-scale">
            <h2 class="text-4xl md:text-5xl font-heading mb-10 leading-tight">
                Ready to build secure AI workflows with confidential computing?
            </h2>
            <a href="/contact" class="inline-block bg-primary text-black font-semibold py-4 px-10 hover:bg-primary-dark transition-colors">
                Contact Us
            </a>
        </div>
    </section>
    
    <Footer slot="footer" />
</Layout>

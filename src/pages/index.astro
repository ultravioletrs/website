---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Newsletter from '../components/Newsletter.astro';
import { Image } from 'astro:assets';

import ccImage from '../assets/mockups/cube_dashboard.png';
import prismConceptImage from '../assets/mockups/prism_dashboard.png';
import openSourceImage from '../assets/open-source.png';

import ifLogo from '../assets/logos/if.png';
import etfLogo from '../assets/logos/etf.png';
import euLogo from '../assets/logos/eu.png';
import telefonicaLogo from '../assets/logos/telefonica.png';
import vttLogo from '../assets/logos/vtt.png';
import fujitsuLogo from '../assets/logos/fujitsu.png';
import fraunhoferLogo from '../assets/logos/fraunhofer.png';
import tnoLogo from '../assets/logos/tno.png';
import ericssonLogo from '../assets/logos/ericsson.png';
import nokiaLogo from '../assets/logos/nokia.png';
import insermLogo from '../assets/logos/inserm.png';
import tueLogo from '../assets/logos/tue.png';
import thalesLogo from '../assets/logos/thales.png';
import imdeaLogo from '../assets/logos/imdea.svg';
import lfLogo from '../assets/logos/lf.png';
import cccLogo from '../assets/logos/ccc.png';

const title = "Open Source Confidential Computing & Secure AI Platform | Ultraviolet";

const clientLogos = [
    { src: ifLogo, alt: "IF", class: "h-10" },
    { src: etfLogo, alt: "ETF", class: "h-14" },
    { src: euLogo, alt: "EU", class: "h-10" },
    { src: telefonicaLogo, alt: "Telefonica", class: "h-8" },
    { src: vttLogo, alt: "VTT", class: "h-8" },
    { src: fujitsuLogo, alt: "Fujitsu", class: "h-8" },
    { src: fraunhoferLogo, alt: "Fraunhofer", class: "h-6" },
    { src: tnoLogo, alt: "TNO", class: "h-8" },
    { src: ericssonLogo, alt: "Ericsson", class: "h-16" },
    { src: nokiaLogo, alt: "Nokia", class: "h-16" },
    { src: insermLogo, alt: "Inserm", class: "h-14" },
    { src: tueLogo, alt: "TUE", class: "h-8" },
    { src: thalesLogo, alt: "Thales", class: "h-20" },
    { src: imdeaLogo, alt: "Imdea", class: "h-10" }
];
---

<Layout title={title}>
	<Header slot="header" />
	
	<Hero
        alignment="center"
		title="Confidential Computing<br />for Enterprise AI"
		description="The open-source platform for secure collaborative AI and private LLM deployment. Protect your data in use, from edge to cloud."
		ctaText="Explore Products"
		ctaLink="/products"
	/>

	<section class="border-b border-border py-12">
		<div class="px-4 text-center">
      <h2 class="text-sm font-body text-text-muted mb-8 tracking-widest uppercase">Our Memberships</h2>
			<div class="flex justify-center flex-wrap gap-12 items-center opacity-80 hover:opacity-100 transition-opacity">
				<a href="https://www.linuxfoundation.org/" target="_blank">
                    <Image src={lfLogo} alt="Linux Foundation" class="h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all" loading="eager" />
                </a>
                <a href="https://confidentialcomputing.io/" target="_blank">
                    <Image src={cccLogo} alt="Confidential Computing Consortium" class="h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all" loading="eager" />
                </a>
			</div>
		</div>
	</section>

    <section class="bg-white dark:bg-zinc-900 border-b border-border transition-colors duration-300">
    <div class="px-4 py-10 text-center border-b border-border">
      <h2 class="text-sm font-body text-text-muted tracking-widest uppercase">Our Clients and Partners</h2>
    </div>
        <div class="overflow-hidden py-6">
            <div class="clients-marquee-track flex w-max items-center">
                {[...clientLogos, ...clientLogos].map((logo, index) => {
                    const isDuplicate = index >= clientLogos.length;

                    return (
                        <div
                            class="clients-marquee-item flex justify-center items-center px-10 py-6"
                            aria-hidden={isDuplicate ? 'true' : undefined}
                        >
                            <Image src={logo.src} alt={logo.alt} class={`${logo.class} w-auto object-contain grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all dark:brightness-0 dark:invert`} loading="lazy" />
                        </div>
                    );
                })}
            </div>
        </div>
    </section>

    <section id="cube-ai" class="py-24 border-b border-border bg-background">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="lg:grid lg:grid-cols-12 lg:gap-12 xl:gap-16 lg:items-center">
                <div class="mb-12 lg:mb-0 lg:col-span-5">
                    <div class="mb-6 flex items-center text-sm font-bold text-primary uppercase tracking-wider">
                        <span class="w-2 h-1 bg-primary mr-3 inline-block"></span> Cube AI <span class="w-2 h-1 bg-primary ml-3 inline-block"></span>
                    </div>
                    <h2 class="text-4xl md:text-5xl font-heading mb-6 text-text-main leading-tight">
                        Uncompromising Confidentiality
                    </h2>
                    <div class="mb-8 text-lg text-text-muted leading-relaxed space-y-4">
                        <p class="font-medium text-text-main text-xl">Run LLMs inside hardware-based Trusted Execution Environments (AMD SEV, Intel TDX).</p>
                        <p>Cloud operators cannot access prompts, weights, or outputs.</p>
                        <ul class="space-y-3 mt-4">
                            <li class="flex items-start">
                                <i class="fas fa-check text-primary mt-1.5 mr-3"></i>
                                <span>Enforce governance at runtime.</span>
                            </li>
                            <li class="flex items-start">
                                <i class="fas fa-check text-primary mt-1.5 mr-3"></i>
                                <span>Generate verifiable audit logs.</span>
                            </li>
                            <li class="flex items-start">
                                <i class="fas fa-check text-primary mt-1.5 mr-3"></i>
                                <span>Prevent prompt injection at the infrastructure layer.</span>
                            </li>
                        </ul>
                    </div>
                    <a href="/cube" class="mt-4 bg-transparent border border-dashed border-border text-text-main font-medium py-3 px-8 hover:bg-surface transition-colors inline-block uppercase tracking-wide">
                        Explore Cube
                    </a>
                </div>
                <div class="flex justify-center items-center lg:col-span-7">
                     <Image class="w-full h-auto border border-border" src={ccImage} alt="Cube AI Dashboard" loading="lazy" />
                </div>
            </div>
        </div>
    </section>

    <section id="prism-ai" class="py-24 border-b border-border bg-background">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="lg:grid lg:grid-cols-12 lg:gap-12 xl:gap-16 lg:items-center">
                <div class="mb-12 lg:mb-0 lg:col-span-5">
                    <div class="mb-6 flex items-center text-sm font-bold text-primary uppercase tracking-wider">
                        <span class="w-2 h-1 bg-primary mr-3 inline-block"></span> Prism AI <span class="w-2 h-1 bg-primary ml-3 inline-block"></span>
                    </div>
                    <h2 class="text-4xl md:text-5xl font-heading mb-6 text-text-main leading-tight">
                        Secure Multi-Party Collaboration
                    </h2>
                    <div class="mb-8 text-lg text-text-muted leading-relaxed space-y-4">
                        <p class="font-medium text-text-main text-xl">Unlock distributed data without exposing intellectual property.</p>
                        <ul class="space-y-3 mt-4">
                            <li class="flex items-start">
                                <span class="w-1.5 h-1.5 bg-primary rounded-full mt-2.5 mr-3 flex-shrink-0"></span>
                                <span>Hardware-backed Remote Attestation</span>
                            </li>
                            <li class="flex items-start">
                                <span class="w-1.5 h-1.5 bg-primary rounded-full mt-2.5 mr-3 flex-shrink-0"></span>
                                <span>Hierarchical RBAC (Dataset Providers vs Algorithm Providers)</span>
                            </li>
                            <li class="flex items-start">
                                <span class="w-1.5 h-1.5 bg-primary rounded-full mt-2.5 mr-3 flex-shrink-0"></span>
                                <span>Policy-driven orchestration</span>
                            </li>
                            <li class="flex items-start">
                                <span class="w-1.5 h-1.5 bg-primary rounded-full mt-2.5 mr-3 flex-shrink-0"></span>
                                <span>aTLS-secured in-enclave execution</span>
                            </li>
                        </ul>
                        <p class="mt-6 border-l border-primary pl-4 italic">Compete on insight — not on who can risk more data.</p>
                    </div>
                    <a href="/prism" class="mt-4 bg-transparent border border-dashed border-border text-text-main font-medium py-3 px-8 hover:bg-surface transition-colors inline-block uppercase tracking-wide">
                        Explore Prism
                    </a>
                </div>
                <div class="flex justify-center items-center lg:col-span-7">
                     <Image class="w-full h-auto border border-border" src={prismConceptImage} alt="Prism AI Dashboard" loading="lazy" />
                </div>
            </div>
        </div>
    </section>

    <section id="cocos-ai" class="py-24 border-b border-border bg-background">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="lg:grid lg:grid-cols-2 lg:gap-24 lg:items-center">
                <div class="mb-10 lg:mb-0">
                    <div class="mb-6 flex items-center text-sm font-bold text-primary uppercase tracking-wider">
                        <span class="w-2 h-1 bg-primary mr-3 inline-block"></span> Cocos AI <span class="w-2 h-1 bg-primary ml-3 inline-block"></span>
                    </div>
                    <h2 class="text-4xl md:text-5xl font-heading mb-6 text-text-main leading-tight">
                        The Open-Source Standard
                    </h2>
                    <div class="mb-8 text-lg text-text-muted leading-relaxed space-y-4">
                        <p class="font-medium text-text-main text-xl">True security requires transparency.</p>
                        <p>Cocos AI is fully open source, independently auditable, and community governed.</p>
                    </div>
                    <a href="/cocos" class="mt-4 bg-transparent border border-dashed border-border text-text-main font-medium py-3 px-8 hover:bg-surface transition-colors inline-block uppercase tracking-wide">
                        Explore Cocos
                    </a>
                </div>
                <div class="flex justify-center items-center">
                     <Image class="w-full h-auto border border-border opacity-80" src={openSourceImage} alt="Cocos AI architecture diagram" loading="lazy" />
                </div>
            </div>
        </div>
    </section>
    
    <section class="py-24 bg-surface bg-opacity-50 text-center">
        <div class="max-w-3xl mx-auto px-4">
            <h2 class="text-4xl md:text-5xl font-heading mb-10 leading-tight">
                Ready to build secure AI workflows with confidential computing?
            </h2>
            <a href="/products" class="inline-block bg-primary text-black font-semibold py-4 px-10 hover:bg-primary-dark transition-colors">
                Explore Our Products
            </a>
        </div>
    </section>
    
    <Footer slot="footer" />
</Layout>

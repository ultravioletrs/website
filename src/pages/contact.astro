---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Contact Ultraviolet - Get in Touch for Secure AI Solutions";
const description = "Contact Ultraviolet for inquiries about confidential computing, secure collaborative AI, and TEE solutions.";

const email = "info@ultraviolet.rs";
const githubOrg = "https://github.com/ultravioletrs";
const linkedin = "https://www.linkedin.com/company/ultravioletrs";
const twitter = "https://twitter.com/ultravioletrs";
const contactApiEndpoint = "/api/contact";
---

<Layout title={title} description={description}>
    <Header slot="header" />

    <section id="header" class="pt-20">
        <div class="w-full relative">
            <div class="flex items-center justify-center h-[300px] overflow-hidden bg-background">
                <img src="/img/header.avif" alt="pattern-white" class="w-full h-full object-cover object-top" loading="lazy" />
            </div>
        </div>
    </section>

    <section class="py-16 bg-background">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
                <div class="reveal-left">
                    <p class="text-sm font-bold text-primary uppercase tracking-widest mb-4">Contact</p>
                    <h1 class="text-4xl lg:text-5xl font-heading mb-6 text-text-main font-medium">Talk to our team</h1>
                    <p class="text-xl text-text-muted font-body mb-8">
                        Whether you're exploring confidential computing solutions or deploying secure AI infrastructure, reach out. We reply quickly.
                    </p>
                    <div class="flex flex-wrap gap-4">
                        <a href={`mailto:${email}`} class="inline-flex items-center px-8 py-3 bg-primary text-black font-medium border border-primary hover:bg-primary-dark transition-colors uppercase tracking-wide">
                            Email Us
                        </a>
                        <a href={linkedin} target="_blank" class="inline-flex items-center px-8 py-3 bg-transparent text-text-main font-medium border border-border hover:bg-surface transition-colors uppercase tracking-wide">
                            Connect on LinkedIn
                        </a>
                    </div>
                </div>

                <div class="bg-surface p-8 border border-border reveal-right">
                    <div>
                        <p class="text-sm font-bold text-text-muted uppercase tracking-widest mb-2">Primary contact</p>
                        <a href={`mailto:${email}`} class="text-xl font-semibold text-primary hover:text-primary-dark transition-colors">
                            {email}
                        </a>
                        <p class="mt-2 text-sm text-text-muted">
                            Best for architecture reviews, production deployments, and security discussions.
                        </p>
                    </div>

                    <div class="my-6 border-t border-border"></div>

                    <div class="space-y-3 text-sm">
                        <div class="flex items-center justify-between">
                            <span class="text-text-muted">GitHub</span>
                            <a href={githubOrg} target="_blank" rel="noopener noreferrer" class="font-medium text-text-main hover:text-primary transition-colors">
                                github.com/ultravioletrs
                            </a>
                        </div>

                        <div class="flex items-center justify-between">
                            <span class="text-text-muted">LinkedIn</span>
                            <a href={linkedin} target="_blank" rel="noopener noreferrer" class="font-medium text-text-main hover:text-primary transition-colors">
                                Ultraviolet
                            </a>
                        </div>

                        <div class="flex items-center justify-between">
                            <span class="text-text-muted">Twitter</span>
                            <a href={twitter} target="_blank" rel="noopener noreferrer" class="font-medium text-text-main hover:text-primary transition-colors">
                                @ultravioletrs
                            </a>
                        </div>
                    </div>

                    <p class="mt-6 text-xs text-text-muted">
                        We typically respond within 1–2 business days.
                    </p>
                </div>
            </div>
            <hr class="border-border mt-16" />
        </div>
    </section>

    <section class="py-16 bg-background">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12 reveal">
                <h2 class="text-3xl font-heading mb-4 text-text-main font-medium">Choose the fastest path</h2>
                <p class="text-lg text-text-muted font-body">Email works best for technical discussions. GitHub is ideal for issues and PRs.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <a href={`mailto:${email}`} class="bg-surface p-8 border border-border hover:border-primary transition-all group reveal reveal-delay-1">
                    <p class="text-sm font-bold text-text-muted uppercase tracking-widest mb-2">Email</p>
                    <h3 class="text-xl font-heading mb-4 text-text-main font-medium">Production & Deployments</h3>
                    <p class="text-text-muted font-body mb-6">
                        Architecture questions, rollout plans, security reviews, and enterprise deployments.
                    </p>
                    <p class="font-medium text-primary group-hover:text-primary-dark transition-colors">Email us →</p>
                </a>

                <a href={githubOrg} target="_blank" rel="noopener noreferrer" class="bg-surface p-8 border border-border hover:border-primary transition-all group reveal reveal-delay-2">
                    <p class="text-sm font-bold text-text-muted uppercase tracking-widest mb-2">GitHub</p>
                    <h3 class="text-xl font-heading mb-4 text-text-main font-medium">Open-source Support</h3>
                    <p class="text-text-muted font-body mb-6">
                        Bugs, feature requests, roadmap discussions, and contributions.
                    </p>
                    <p class="font-medium text-primary group-hover:text-primary-dark transition-colors">Open GitHub →</p>
                </a>

                <a href={linkedin} target="_blank" rel="noopener noreferrer" class="bg-surface p-8 border border-border hover:border-primary transition-all group reveal reveal-delay-3">
                    <p class="text-sm font-bold text-text-muted uppercase tracking-widest mb-2">LinkedIn</p>
                    <h3 class="text-xl font-heading mb-4 text-text-main font-medium">Partnerships</h3>
                    <p class="text-text-muted font-body mb-6">
                        Research collaboration, ecosystem partnerships, and business inquiries.
                    </p>
                    <p class="font-medium text-primary group-hover:text-primary-dark transition-colors">Visit LinkedIn →</p>
                </a>
            </div>
            <hr class="border-border mt-16" />
        </div>
    </section>

    <section class="py-16 bg-background">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12 reveal">
                <h2 class="text-3xl font-heading mb-4 text-text-main font-medium">Send a message</h2>
                <p class="text-lg text-text-muted font-body">Send details directly from the form. If delivery fails, use email fallback.</p>
            </div>

            <form class="space-y-6 reveal" method="post" action={contactApiEndpoint} data-contact-form>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <label class="flex flex-col gap-2">
                        <span class="text-sm text-text-muted font-medium">Name</span>
                        <input
                            class="w-full px-4 py-3 bg-surface border border-border text-text-main placeholder-text-muted focus:outline-none focus:border-primary transition-colors"
                            name="name"
                            autocomplete="name"
                            required
                        />
                    </label>

                    <label class="flex flex-col gap-2">
                        <span class="text-sm text-text-muted font-medium">Email</span>
                        <input
                            class="w-full px-4 py-3 bg-surface border border-border text-text-main placeholder-text-muted focus:outline-none focus:border-primary transition-colors"
                            name="email"
                            type="email"
                            autocomplete="email"
                            required
                        />
                    </label>
                </div>

                <label class="flex flex-col gap-2">
                    <span class="text-sm text-text-muted font-medium">Message</span>
                    <textarea
                        class="w-full px-4 py-3 bg-surface border border-border text-text-main placeholder-text-muted focus:outline-none focus:border-primary transition-colors min-h-[160px]"
                        name="message"
                        required
                        placeholder="What are you building? What do you need help with? Any security or compliance requirements?"
                    ></textarea>
                </label>

                <div class="hidden" aria-hidden="true">
                    <label for="company">Company</label>
                    <input id="company" name="company" tabindex="-1" autocomplete="off" />
                </div>

                <div class="flex flex-wrap items-center gap-4">
                    <button class="inline-flex items-center px-8 py-3 bg-primary text-black font-medium border border-primary hover:bg-primary-dark transition-colors uppercase tracking-wide" type="submit" data-contact-submit>
                        Send Message
                    </button>

                    <a class="inline-flex items-center px-8 py-3 bg-transparent text-text-main font-medium border border-border hover:bg-surface transition-colors uppercase tracking-wide" href={`mailto:${email}?subject=${encodeURIComponent("Ultraviolet — Inquiry")}`}>
                        Send via Email
                    </a>
                </div>

                <p class="text-sm text-text-muted">
                    Prefer GitHub? Open an issue in our <a href={githubOrg} target="_blank" rel="noopener noreferrer" class="font-semibold text-primary hover:text-primary-dark transition-colors">repositories</a>.
                </p>

                <p class="min-h-6 text-sm text-text-muted" role="status" aria-live="polite" data-contact-status></p>
            </form>
            <hr class="border-border mt-16" />
        </div>
    </section>

    <section id="address" class="py-16 bg-background">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
                <div class="md:col-span-4 bg-surface p-8 border border-border h-full flex flex-col justify-center reveal-left">
                     <h3 class="text-2xl font-heading mb-6 text-text-main font-medium">ULTRAVIOLET</h3>
                     <p class="text-lg text-text-muted font-body leading-relaxed">
                        Bulevar Arsenija Carnojevica 103<br>
                        11000 Belgrade<br>
                        Serbia
                     </p>
                </div>
                <div class="md:col-span-8 reveal-right">
                     <iframe
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2268.377985058479!2d20.409364951467016!3d44.82032882973188!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x475a709e828cd3b7%3A0x5c11252c64fcf58a!2sBulevar%20Arsenija%20Carnojevica%20103%2C%2011070%2C%20Novi%20Beograd!5e0!3m2!1sen!2srs!4v1661888661151!5m2!1sen!2srs"
                        width="100%" height="400" style="border: 0" allowfullscreen="" loading="lazy" class="border p-2 border-border shadow-none"></iframe>
                </div>
            </div>
        </div>
    </section>

    <Footer slot="footer" />
</Layout>

<script is:inline>
(() => {
    const form = document.querySelector("[data-contact-form]");
    if (!(form instanceof HTMLFormElement)) return;

    const statusEl = document.querySelector("[data-contact-status]");
    const submitButton = form.querySelector("[data-contact-submit]");
    if (!(statusEl instanceof HTMLElement)) return;
    if (!(submitButton instanceof HTMLButtonElement)) return;

    const defaultLabel = submitButton.textContent?.trim() || "Send Message";

    const setStatus = (text, tone = "muted") => {
        statusEl.textContent = text;
        statusEl.classList.remove("text-text-muted", "text-red-500", "text-green-500");
        if (tone === "success") {
            statusEl.classList.add("text-green-500");
            return;
        }
        if (tone === "error") {
            statusEl.classList.add("text-red-500");
            return;
        }
        statusEl.classList.add("text-text-muted");
    };

    form.addEventListener("submit", async (event) => {
        event.preventDefault();
        submitButton.disabled = true;
        submitButton.setAttribute("aria-busy", "true");
        submitButton.textContent = "Sending...";
        setStatus("Sending your message...");

        try {
            const response = await fetch(form.action, {
                method: "POST",
                body: new FormData(form),
                headers: {
                    Accept: "application/json",
                },
            });

            let payload = null;
            try {
                payload = await response.json();
            } catch {
                payload = null;
            }

            if (!response.ok || !payload?.ok) {
                throw new Error(
                    payload?.error ||
                    "Unable to send your message. Please use direct email."
                );
            }

            form.reset();
            setStatus(
                payload?.message || "Thanks! Your message has been sent.",
                "success"
            );
        } catch (error) {
            setStatus(
                error instanceof Error
                    ? error.message
                    : "Unable to send your message. Please use direct email.",
                "error"
            );
        } finally {
            submitButton.disabled = false;
            submitButton.removeAttribute("aria-busy");
            submitButton.textContent = defaultLabel;
        }
    });
})();
</script>
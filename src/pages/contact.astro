---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Newsletter from '../components/Newsletter.astro';

const title = "Contact Ultraviolet - Get in Touch for Secure AI Solutions";
const description = "Contact Ultraviolet for inquiries about confidential computing, secure collaborative AI, and TEE solutions.";
---

<Layout title={title} description={description}>
    <Header slot="header" />

    <section id="header" class="pt-20">
        <div class="w-full relative">
            <div class="flex items-center justify-center h-[300px] overflow-hidden border-b border-border bg-background">
                <img src="/img/header.avif" alt="pattern-white" class="w-full h-full object-cover object-top" loading="lazy" />
            </div>
        </div>
    </section>

    <section id="contact" class="py-16 bg-surface border-b border-border">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                <div class="bg-background p-8 border border-border">
                     <h2 class="text-2xl font-heading mb-6 font-medium text-text-main">Get In Touch</h2>
                     <p class="mb-4 text-lg font-body">
                        <i class="fas fa-envelope mr-3 text-primary"></i><a href="mailto:info@ultraviolet.rs" class="text-text-muted hover:text-primary transition-colors">info@ultraviolet.rs</a>
                     </p>
                     <p class="mb-4 text-lg font-body">
                        <i class="fab fa-gitter mr-3 text-primary"></i><a href="https://app.gitter.im/#/room/#Ultraviolet_community:gitter.im"
                        target="_blank" class="text-text-muted hover:text-primary transition-colors">Chat on Gitter</a>
                     </p>
                </div>
                <div class="bg-background p-8 border border-border">
                    <h2 class="text-2xl font-heading mb-6 font-medium text-text-main">Follow Us</h2>
                    <ul class="flex flex-col space-y-4 list-none p-0 m-0 font-body">
                        <li>
                             <a href="https://twitter.com/ultravioletrs" target="_blank" class="flex items-center text-text-muted hover:text-primary transition-colors text-lg">
                                <i class="fab fa-twitter text-2xl mr-4 w-8 text-center text-primary"></i>Twitter
                            </a>
                        </li>
                        <li>
                            <a href="https://www.linkedin.com/company/ultravioletrs" target="_blank" class="flex items-center text-text-muted hover:text-primary transition-colors text-lg">
                                <i class="fab fa-linkedin text-2xl mr-4 w-8 text-center text-primary"></i>LinkedIn
                            </a>
                        </li>
                        <li>
                             <a href="https://github.com/ultravioletrs" target="_blank" class="flex items-center text-text-muted hover:text-primary transition-colors text-lg">
                                <i class="fab fa-github text-2xl mr-4 w-8 text-center text-primary"></i>GitHub
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <section id="address" class="py-16 bg-background">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
                <div class="md:col-span-4 bg-surface p-8 border border-border h-full flex flex-col justify-center">
                     <h3 class="text-2xl font-heading mb-6 text-text-main font-medium">ULTRAVIOLET</h3>
                     <p class="text-lg text-text-muted font-body leading-relaxed">
                        Bulevar Arsenija Carnojevica 103<br>
                        11000 Belgrade<br>
                        Serbia
                     </p>
                </div>
                <div class="md:col-span-8">
                     <iframe
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2268.377985058479!2d20.409364951467016!3d44.82032882973188!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x475a709e828cd3b7%3A0x5c11252c64fcf58a!2sBulevar%20Arsenija%20Carnojevica%20103%2C%2011070%2C%20Novi%20Beograd!5e0!3m2!1sen!2srs!4v1661888661151!5m2!1sen!2srs"
                        width="100%" height="400" style="border: 0" allowfullscreen="" loading="lazy" class="border p-2 border-border shadow-none"></iframe>
                </div>
            </div>
        </div>
    </section>

    <Newsletter />

    <Footer slot="footer" />
</Layout>

---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';

const entries = (await getCollection('use-cases')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const title = "Use Cases | Ultraviolet";
const description = "Explore real-world use cases for Ultraviolet's confidential computing and secure AI platforms across healthcare, finance, research, and more.";
---

<Layout title={title} description={description}>
	<Header slot="header" />

	<div class="pt-0">
		<Hero
			title="Use Cases"
			description="Explore how organizations leverage confidential computing and privacy-preserving AI to solve real-world challenges across industries."
			alignment="center"
		/>
	</div>

	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
		<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
			{entries.map((entry) => (
				<a
					href={`/use-cases/${entry.slug}`}
					class="border border-border bg-card transition-colors duration-200 hover:bg-surface flex flex-col h-full reveal"
				>
					<div class="p-6 flex flex-col flex-1">
						{entry.data.category && (
							<div class="mb-3">
								<span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium bg-primary/10 text-primary-text">
									{entry.data.category}
								</span>
							</div>
						)}
						<h2 class="text-lg font-bold text-text-main font-heading mb-2 line-clamp-2">{entry.data.title}</h2>
						<p class="text-sm text-text-muted line-clamp-3 mb-4 font-body flex-1">{entry.data.excerpt || entry.data.description}</p>
						<p class="text-xs text-text-muted mt-auto">
							{entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })} · {Math.ceil(entry.body.split(/\s+/).length / 200)} min read
						</p>
					</div>
				</a>
			))}
		</div>
	</div>

	<Footer slot="footer" />
</Layout>

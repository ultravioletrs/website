---
interface Props {
  title: string;
  price: string;
  pricePeriod?: string;
  features: string[];
  ctaText: string;
  ctaLink: string;
  highlight?: boolean;
  comingSoon?: boolean;
}

const { title, price, pricePeriod = "/month", features, ctaText, ctaLink, highlight = false, comingSoon = false } = Astro.props;

const borderClass = highlight ? 'border-primary ring-1 ring-primary' : 'border-border';
const btnClass = comingSoon 
  ? 'bg-surface text-text-muted border border-border border-dashed cursor-not-allowed'
  : (highlight ? 'bg-primary text-black border border-primary hover:bg-primary-dark uppercase tracking-wide' : 'bg-transparent text-text-main border border-border hover:bg-surface border-dashed uppercase tracking-wide');
---

<div class={`flex flex-col p-8 bg-background border ${borderClass} shadow-none h-full transition-colors`}>
  <h3 class="text-xl font-heading font-medium text-text-main text-center uppercase tracking-wide mb-4">{title}</h3>
  <div class="flex justify-center items-baseline my-8">
    <span class="text-4xl font-bold font-heading text-text-main">{price}</span>
    {price !== 'Free' && price !== 'Contact us' && <span class="text-text-muted font-medium ml-2">{pricePeriod}</span>}
  </div>
  <ul class="space-y-4 mb-8 flex-1">
    {features.map((feature) => (
      <li class="flex items-start text-text-muted text-sm font-body">
        <svg class="h-5 w-5 text-primary-text mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        <span>{feature}</span>
      </li>
    ))}
  </ul>
  <div class="mt-auto">
    <a href={ctaLink} class={`w-full block text-center py-4 font-medium transition-colors ${btnClass}`}>
      {comingSoon ? 'Coming Soon' : ctaText}
    </a>
  </div>
</div>
